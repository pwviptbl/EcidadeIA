{
  "descricao": "Exemplo minimo de catalogo enriquecido para orientar analistas no preenchimento semantico.",
  "domain": "cadastro",
  "exemplos": [
    {
      "pergunta": "Compare o IPTU 2025 e 2026 e explique os principais fatores de aumento",
      "uses": [
        "cadastro.iptucalc",
        "valor_venal_terreno",
        "valor_isencao_iptu"
      ]
    },
    {
      "pergunta": "Quantos imoveis isentos de IPTU existem?",
      "uses": [
        "cadastro.iptucalc",
        "valor_isencao_iptu"
      ]
    },
    {
      "pergunta": "Quantas ruas nos temos?",
      "uses": [
        "cadastro.ruas"
      ]
    }
  ],
  "intencoes": {
    "compare_periods": {
      "descricao": "Compara metricas entre dois periodos ou exercicios.",
      "estrategia_comparacao": "same_entity",
      "gatilhos": [
        "compare",
        "comparar",
        "aumento",
        "reducao",
        "redução",
        "variacao",
        "variação",
        "evolucao",
        "evolução"
      ],
      "regras": [
        "Comparar a mesma entidade quando houver entity_key.",
        "Nao usar media por periodo como unica evidencia de variacao.",
        "Nao inferir causa sem metrica retornada."
      ],
      "required_dimensions": [
        "time"
      ],
      "required_entity_key": true,
      "template_padrao": "compare_periods_same_entity"
    },
    "count_records": {
      "default_aggregation": "count",
      "descricao": "Conta registros de uma entidade ou tabela.",
      "gatilhos": [
        "quantos",
        "quantas",
        "total",
        "contar",
        "existem",
        "existe"
      ]
    }
  },
  "metricas": {
    "valor_isencao_iptu": {
      "apelidos": [
        "imoveis isentos",
        "isencao de iptu",
        "valor de isencao"
      ],
      "significado_contagem": "Quando usado com filtro positivo, conta matriculas com isencao registrada no calculo.",
      "effect_on_final_value": "decreases_when_increases",
      "explain_variation": true,
      "expressao": "j23_vlrisen",
      "grain": [
        "matricula",
        "exercicio"
      ],
      "is_final_metric": false,
      "rotulo": "Valor de isencao do IPTU",
      "semantica_filtros": {
        "isento_iptu": "coalesce(j23_vlrisen, 0) > 0"
      },
      "tabela": "cadastro.iptucalc",
      "unidade": "BRL"
    },
    "valor_venal_terreno": {
      "apelidos": [
        "fatores de aumento",
        "variacao do iptu",
        "comparacao de iptu"
      ],
      "effect_on_final_value": "increases_when_increases",
      "explain_variation": true,
      "expressao": "j23_vlrter",
      "grain": [
        "matricula",
        "exercicio"
      ],
      "is_final_metric": false,
      "rotulo": "Valor venal do terreno",
      "tabela": "cadastro.iptucalc",
      "unidade": "BRL"
    }
  },
  "rotulo": "Cadastro",
  "schema_principal": "cadastro",
  "tabelas": {
    "cadastro.iptucalc": {
      "apelidos": [
        "compare iptu entre anos",
        "fatores de aumento do iptu",
        "imoveis isentos de iptu"
      ],
      "chave_negocio": [
        "j23_matric"
      ],
      "chave_primaria": [
        "j23_anousu",
        "j23_matric"
      ],
      "coluna_tempo": "j23_anousu",
      "colunas": {
        "j23_aliq": {
          "descricao": "Aliquota gerada para o iptu",
          "effect_on_final_value": "increases_when_increases",
          "is_final_metric": false,
          "papel": "medida",
          "tipo": "double precision"
        },
        "j23_anousu": {
          "descricao": "Exercicio do calculo",
          "papel": "coluna_tempo",
          "tipo": "integer"
        },
        "j23_matric": {
          "descricao": "Matricula do imovel do arquivo iptubase",
          "papel": "chave_negocio",
          "tipo": "integer"
        },
        "j23_vlrisen": {
          "descricao": "Valor gerado de isencao no calculo do iptu",
          "effect_on_final_value": "decreases_when_increases",
          "semantica_filtros": {
            "isento_iptu": "coalesce(j23_vlrisen, 0) > 0"
          },
          "is_final_metric": false,
          "metrica": "valor_isencao_iptu",
          "papel": "medida",
          "tipo": "double precision"
        },
        "j23_vlrter": {
          "descricao": "Valor venal do terreno gerado no calculo",
          "effect_on_final_value": "increases_when_increases",
          "is_final_metric": false,
          "metrica": "valor_venal_terreno",
          "papel": "medida",
          "tipo": "double precision"
        }
      },
      "descricao": "Dados dos calculos de iptu, onde consta o valor venal do terreno e outros dados.",
      "semantica_filtros": {
        "isento_iptu": "coalesce(j23_vlrisen, 0) > 0"
      },
      "grao": [
        "exercicio",
        "matricula"
      ],
      "recomendada": true,
      "significado_contagem": "Uma linha representa uma matricula em um exercicio de calculo."
    },
    "cadastro.ruas": {
      "apelidos": [
        "quantas ruas",
        "total de ruas",
        "logradouros do municipio"
      ],
      "chave_negocio": [
        "j14_codigo"
      ],
      "chave_primaria": [
        "j14_codigo"
      ],
      "colunas": {
        "j14_codigo": {
          "descricao": "Codigo da rua",
          "papel": "chave_negocio",
          "tipo": "integer"
        },
        "j14_nome": {
          "descricao": "Nome da rua",
          "papel": "dimensao",
          "tipo": "character varying"
        },
        "j14_tipo": {
          "descricao": "Tipo do logradouro",
          "papel": "dimensao",
          "tipo": "integer"
        }
      },
      "descricao": "Cadastro de todas as ruas e avenidas do municipio",
      "grao": [
        "logradouro"
      ],
      "recomendada": true,
      "significado_contagem": "Uma linha representa um logradouro cadastrado."
    }
  },
  "templates": {
    "compare_periods_same_entity": {
      "allowed_aggregations": [
        "count",
        "avg_delta",
        "sum_delta",
        "avg_period"
      ],
      "intent": "compare_periods",
      "requires": [
        "table",
        "entity_key",
        "time_key",
        "metrics",
        "period_a",
        "period_b"
      ],
      "strategy": "self_join_same_table"
    }
  }
}
